# ── Hikvision Device ──────────────────────────────────────────────────────────
# IP address of your Hikvision access control terminal
HIK_HOST=192.168.1.100
# Device username (default is admin)
HIK_USER=admin
# Device password
HIK_PASS=YOUR_DEVICE_PASSWORD

# ── MQTT Broker ───────────────────────────────────────────────────────────────
# IP address of your MQTT broker (EMQX, Mosquitto, etc.)
MQTT_HOST=192.168.1.10
# MQTT broker port (default: 1883)
MQTT_PORT=1883
# MQTT credentials
MQTT_USER=YOUR_MQTT_USERNAME
MQTT_PASS=YOUR_MQTT_PASSWORD
# Set to true if your broker requires TLS
MQTT_TLS=false

# ── Topics ────────────────────────────────────────────────────────────────────
# Base topic for all published events.
# Events will be published to:
#   {MQTT_TOPIC_BASE}/{major}/{minor}  → specific event type
#   {MQTT_TOPIC_BASE}/any             → all events (catch-all)
MQTT_TOPIC_BASE=hikvision/outdoor/event

# ── Behavior ──────────────────────────────────────────────────────────────────
# MQTT QoS level: 0 = fire-and-forget, 1 = at least once (recommended)
MQTT_QOS=1
# Retain the last event on the /any topic (true/false)
MQTT_RETAIN_ANY=false
# Log heartbeat every N received. Set to 0 to log all heartbeats.
HEARTBEAT_LOG_INTERVAL=10
# Seconds to wait before reconnecting after a connection failure
# Important: do not set this too low or the device may temporarily block connections
RECONNECT_DELAY=60

# ── Important ─────────────────────────────────────────────────────────────────
# Do NOT use inline comments in this file (e.g. MQTT_HOST=1.2.3.4 # my broker)
# Docker reads inline comments as part of the value, causing silent failures.
# Use only full-line comments like this one.
